# Application
APP_NAME=AgenticShipping
APP_ENV=development
APP_SECRET_KEY=your-super-secret-key-change-in-production
DEBUG=true
API_V1_PREFIX=/api/v1

# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/agentic_shipping
SYNC_DATABASE_URL=postgresql://postgres:password@localhost:5432/agentic_shipping

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# LLM
GOOGLE_API_KEY=your-google-gemini-api-key
OPENAI_API_KEY=your-openai-api-key
LLM_MODEL=gemini-1.5-pro
LLM_FAST_MODEL=gemini-1.5-flash

# Vector DB
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION_CARRIER_MEMORY=carrier_performance
CHROMA_COLLECTION_ROUTES=route_history

# Shipping Carrier APIs
EASYPOST_API_KEY=your-easypost-api-key
SHIPPO_API_KEY=your-shippo-api-key
FEDEX_API_KEY=your-fedex-api-key
FEDEX_SECRET_KEY=your-fedex-secret
UPS_CLIENT_ID=your-ups-client-id
UPS_CLIENT_SECRET=your-ups-client-secret
DHL_API_KEY=your-dhl-api-key

# Freight / Spot Rate APIs
FREIGHTOS_API_KEY=your-freightos-api-key
FLEXPORT_API_KEY=your-flexport-api-key

# Weather API
OPENWEATHER_API_KEY=your-openweather-api-key

# Maps / Geo
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Insurance
SHIPSURANCE_API_KEY=your-shipsurance-api-key

# Monitoring
SENTRY_DSN=your-sentry-dsn
PROMETHEUS_PORT=9090

# JWT
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Agent Confidence Thresholds
AGENT_AUTO_EXECUTE_THRESHOLD=0.95
AGENT_ESCALATE_THRESHOLD=0.70
AGENT_REJECT_THRESHOLD=0.40

# Sustainability
CARBON_CREDIT_PRICE_PER_TON=25.0
EV_LAST_MILE_PREFERENCE=true
